# ------------------------------------------------------------
func test_ai_base_returns_pass_by_default():
    var ai = AiBase.new()
    var board = Board.new()
    var move = ai.get_move(board, Stone.Type.BLACK)
    assert_eq(move, Vector2i(-1, -1), "未重写应返回 pass")

